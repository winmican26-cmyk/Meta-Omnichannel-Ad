# === META APP CREDENTIALS ===
# From https://developers.facebook.com/apps/<APP_ID>/settings/basic/
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v25.0
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_1234567890
META_PAGE_ID=

# === OAUTH ===
# Must match a "Valid OAuth Redirect URI" registered at
# https://developers.facebook.com/apps/<APP_ID>/fb-login-business/settings/
META_REDIRECT_URI=http://localhost:8765/auth/callback

# Facebook Login for Business — preferred for SaaS / agency use cases.
# Create a Login Configuration at
# https://developers.facebook.com/apps/<APP_ID>/fb-login-business/configurations
# and paste the resulting configuration ID below. When set, OAuth uses
# config_id instead of scope so consent is business-context aware.
META_LOGIN_CONFIG_ID=

# Legacy scope-based OAuth fallback (used only if META_LOGIN_CONFIG_ID is empty).
META_SCOPES=ads_management,ads_read,business_management,pages_show_list,pages_read_engagement,read_insights

LOG_LEVEL=INFO

# === SECURITY ===
# Encrypts OAuth access tokens at rest in SQLite (required for Meta DPA).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# When set to true, exposes /docs, /redoc, /openapi.json (off in production).
ENABLE_API_DOCS=false

# Public base URL of this deployment. Used to build the data-deletion
# confirmation URL returned to Meta. Must match the host you register in
# Meta App Dashboard → App Settings → Data Deletion.
# Local dev:   http://127.0.0.1:8766
# Production:  https://your-domain.example
PUBLIC_BASE_URL=http://127.0.0.1:8766

# === STRIPE (get test keys from https://dashboard.stripe.com/test/apikeys) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
BILLING_SUCCESS_URL=http://localhost:8765/billing/success
BILLING_CANCEL_URL=http://localhost:8765/
